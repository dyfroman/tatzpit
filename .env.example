# Copy to `.env` (repo root for docker compose) or `backend/.env` (local dev).
# Never commit the real .env — it is in .gitignore.

# Alert source: demo | indexer | ssh
TATZPIT_MODE=demo
POLL_INTERVAL_SECONDS=30

# --- indexer mode: Wazuh Indexer (OpenSearch) REST API ---
# Alerts live in the indexer (port 9200), NOT in the manager API (55000).
WAZUH_INDEXER_URL=https://192.168.1.50:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=changeme
WAZUH_INDEXER_INDEX=wazuh-alerts-4.x-*
# Wazuh ships with self-signed certs; set true if you installed real ones.
WAZUH_VERIFY_SSL=false

# --- ssh mode: tail alerts.json on the manager ---
# Use a dedicated read-only user with access to /var/ossec/logs/alerts/.
SSH_HOST=192.168.1.50
SSH_PORT=22
SSH_USER=wazuh-reader
# Prefer key auth; leave SSH_PASSWORD empty when SSH_KEY_PATH is set.
SSH_KEY_PATH=
SSH_PASSWORD=
SSH_ALERTS_PATH=/var/ossec/logs/alerts/alerts.json

# --- demo mode tuning ---
DEMO_ALERT_COUNT=200
DEMO_LIVE_FEED=true
